# Database Configuration
# For Vercel Postgres, these variables are automatically created
# For local development, use a standard PostgreSQL connection string
POSTGRES_PRISMA_URL=postgresql://username:password@host:port/database?pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgresql://username:password@host:port/database
POSTGRES_URL=postgresql://username:password@host:port/database

# Legacy support (optional - Prisma will use POSTGRES_PRISMA_URL first)
DATABASE_URL=postgresql://username:password@host:port/database

# JWT Secret (Required - Generate a secure random string)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your_secure_jwt_secret_key_here

# Server Configuration
PORT=3000
NODE_ENV=production

# Optional: Facebook Ads API (can be configured later in Settings)
# These can be left empty and configured through the app's Settings page
FACEBOOK_ADS_TOKEN=

# Optional: Google Ads API (can be configured later in Settings)
# These can be left empty and configured through the app's Settings page
GOOGLE_ADS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
